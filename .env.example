# ============================================
# Polymarket Multi-Bot Trading System
# Copy to .env and fill in your values
# ============================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALERT_CHAT_ID=your_chat_id

# --- Solana ---
SOLANA_PRIVATE_KEY=your_base58_private_key
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=your_helius_api_key
WALLET_ENCRYPTION_KEY=your_aes256_master_key

# --- Polymarket ---
POLY_PRIVATE_KEY=0x_your_private_key_here
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
FUNDER_ADDRESS=
SIGNATURE_TYPE=2

# --- Binance ---
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# --- Bybit ---
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret

# --- Hyperliquid ---
HYPERLIQUID_API_KEY=your_hyperliquid_api_key
HYPERLIQUID_API_SECRET=your_hyperliquid_api_secret

# --- dYdX ---
DYDX_API_KEY=your_dydx_api_key
DYDX_API_SECRET=your_dydx_api_secret
DYDX_PASSPHRASE=your_dydx_passphrase

# --- System ---
DRY_RUN=true
LOG_LEVEL=INFO
DB_PATH=./data/trading.db
